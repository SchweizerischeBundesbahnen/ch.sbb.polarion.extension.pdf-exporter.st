<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 http://maven.apache.org/xsd/settings-1.0.0.xsd">
    <activeProfiles>
        <activeProfile>github</activeProfile>
    </activeProfiles>
    <profiles>
        <profile>
            <id>github</id>
            <repositories>
                <repository>
                    <id>jfrog_io</id>
                    <name>sbb.jfrog.io/artifactory/polarion-mvn</name>
                    <url>https://sbb.jfrog.io/artifactory/polarion-mvn</url>
                    <releases>
                        <enabled>true</enabled>
                        <updatePolicy>never</updatePolicy>
                    </releases>
                    <!-- Releases resolve from JFrog; snapshots are served by GitHub Packages below. -->
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                </repository>
                <!-- Extension SNAPSHOTs (e.g. 13.0.1-SNAPSHOT) are published to GitHub Packages,
                     not JFrog. Needed to system-test against an unreleased extension build. -->
                <repository>
                    <id>github_packages</id>
                    <name>GitHub Packages (pdf-exporter snapshots)</name>
                    <url>https://maven.pkg.github.com/SchweizerischeBundesbahnen/ch.sbb.polarion.extension.pdf-exporter</url>
                    <releases>
                        <enabled>false</enabled>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                </repository>
            </repositories>
            <pluginRepositories/>
        </profile>
    </profiles>
    <servers>
        <server>
            <id>jfrog_io</id>
            <configuration>
                <httpHeaders>
                    <property>
                        <name>X-JFrog-Art-Api</name>
                        <value>${env.IO_JFROG_SBB_POLARION_TOKEN}</value>
                    </property>
                </httpHeaders>
            </configuration>
        </server>
        <server>
            <id>github_packages</id>
            <username>${env.GITHUB_ACTOR}</username>
            <password>${env.GITHUB_TOKEN}</password>
        </server>
    </servers>
    <mirrors/>
    <pluginGroups/>
    <proxies/>
</settings>
